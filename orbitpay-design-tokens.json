{
  "name": "OrbitPay Finance Design System",
  "version": "1.0.0",
  "brand": {
    "name": "OrbitPay Finance",
    "legalName": "OrbitPay Finance, Inc.",
    "tagline": "Secure. Seamless. Orbital.",
    "domain": "orbitpay.finance"
  },
  "assets": {
    "logo": {
      "primary": {
        "src": "/assets/orbitpay-logo-primary.svg",
        "alt": "OrbitPay Finance Logo",
        "width": 160,
        "height": 40,
        "format": "svg"
      },
      "mark": {
        "src": "/assets/orbitpay-mark.svg",
        "alt": "OrbitPay Mark",
        "width": 40,
        "height": 40,
        "format": "svg"
      },
      "wordmark": {
        "src": "/assets/orbitpay-wordmark.svg",
        "alt": "OrbitPay Finance",
        "width": 120,
        "height": 32,
        "format": "svg"
      },
      "favicon": "/assets/favicon.ico",
      "appleTouchIcon": "/assets/apple-touch-icon.png",
      "maskIcon": "/assets/safari-pinned-tab.svg"
    },
    "watermark": {
      "src": "/assets/orbitpay-watermark.svg",
      "opacity": 0.06,
      "position": "center",
      "size": "60%"
    },
    "patterns": {
      "grid": "/assets/patterns/grid-pattern.svg",
      "orbital": "/assets/patterns/orbital-rings.svg",
      "dots": "/assets/patterns/dot-matrix.svg"
    },
    "allowedImageDomains": [
      "cdn.orbitpay.finance",
      "assets.orbitpay.finance",
      "images.orbitpay.finance",
      "localhost"
    ],
    "placeholder": {
      "src": "/assets/orbitpay-placeholder.svg",
      "bgColor": "#F0F2F5",
      "fallbackText": "OrbitPay"
    }
  },
  "color": {
    "primary": {
      "900": "#06152B",
      "800": "#0A1F44",
      "700": "#0E2B5E",
      "600": "#123878",
      "500": "#164592",
      "400": "#3A6AB5",
      "300": "#6E94D0",
      "200": "#A2BEE5",
      "100": "#D6E4F5",
      "50": "#EFF4FB"
    },
    "accent": {
      "500": "#4A90E2",
      "400": "#6BA5E7",
      "300": "#8CBAEC",
      "600": "#3570C0"
    },
    "neutral": {
      "900": "#0F1115",
      "800": "#1A1D24",
      "700": "#2A2E3A",
      "600": "#3E4450",
      "500": "#5A6070",
      "400": "#7A8295",
      "300": "#A0A8B8",
      "200": "#C8CDD6",
      "100": "#E4E7EC",
      "50": "#F5F6F8",
      "0": "#FFFFFF"
    },
    "semantic": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "info": "#3B82F6"
    },
    "surface": {
      "dark": "#0A1F44",
      "light": "#FFFFFF",
      "card": "#FFFFFF",
      "elevated": "#F8FAFC",
      "overlay": "rgba(10, 31, 68, 0.72)"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "mono": "'JetBrains Mono', 'Fira Code', monospace",
      "display": "'Inter Display', 'Inter', sans-serif"
    },
    "scale": {
      "hero": {"size": "64px", "lineHeight": 1.1, "letterSpacing": "-0.03em", "weight": 700},
      "h1": {"size": "48px", "lineHeight": 1.15, "letterSpacing": "-0.02em", "weight": 700},
      "h2": {"size": "36px", "lineHeight": 1.2, "letterSpacing": "-0.02em", "weight": 600},
      "h3": {"size": "28px", "lineHeight": 1.25, "letterSpacing": "-0.01em", "weight": 600},
      "h4": {"size": "22px", "lineHeight": 1.3, "letterSpacing": "-0.01em", "weight": 600},
      "h5": {"size": "18px", "lineHeight": 1.35, "letterSpacing": "0", "weight": 600},
      "body": {"size": "16px", "lineHeight": 1.6, "letterSpacing": "0", "weight": 400},
      "bodySmall": {"size": "14px", "lineHeight": 1.5, "letterSpacing": "0", "weight": 400},
      "caption": {"size": "12px", "lineHeight": 1.4, "letterSpacing": "0.01em", "weight": 500},
      "label": {"size": "11px", "lineHeight": 1.3, "letterSpacing": "0.04em", "weight": 600}
    }
  },
  "spacing": {
    "unit": 4,
    "scale": [0, 4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80, 96, 128]
  },
  "borderRadius": {
    "none": 0,
    "sm": 4,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "2xl": 24,
    "full": 9999
  },
  "shadow": {
    "sm": "0 1px 2px rgba(10, 31, 68, 0.05)",
    "md": "0 4px 12px rgba(10, 31, 68, 0.08)",
    "lg": "0 8px 24px rgba(10, 31, 68, 0.12)",
    "xl": "0 16px 48px rgba(10, 31, 68, 0.16)",
    "glow": "0 0 24px rgba(74, 144, 226, 0.24)"
  },
  "components": {
    "card": {
      "requiredElements": ["brandLogo", "brandWatermark"],
      "background": "#FFFFFF",
      "borderRadius": 12,
      "border": "1px solid #E4E7EC",
      "shadow": "0 4px 12px rgba(10, 31, 68, 0.08)",
      "padding": 24,
      "logoPosition": "topLeft",
      "watermarkOpacity": 0.04,
      "imagePolicy": "brand_only",
      "fallbackImage": "/assets/orbitpay-placeholder.svg"
    },
    "button": {
      "primary": {
        "background": "#0A1F44",
        "color": "#FFFFFF",
        "borderRadius": 8,
        "padding": "12px 24px",
        "fontWeight": 600
      },
      "secondary": {
        "background": "transparent",
        "color": "#0A1F44",
        "border": "1.5px solid #0A1F44",
        "borderRadius": 8,
        "padding": "12px 24px",
        "fontWeight": 600
      }
    },
    "input": {
      "borderRadius": 8,
      "border": "1.5px solid #E4E7EC",
      "focusBorder": "1.5px solid #4A90E2",
      "focusShadow": "0 0 0 3px rgba(74, 144, 226, 0.15)",
      "padding": "12px 16px"
    },
    "navigation": {
      "height": 64,
      "background": "#FFFFFF",
      "borderBottom": "1px solid #E4E7EC",
      "logoHeight": 32,
      "sticky": true
    }
  },
  "enforcement": {
    "imageValidation": {
      "allowedDomains": ["cdn.orbitpay.finance", "assets.orbitpay.finance"],
      "requireBrandLogo": true,
      "requireWatermark": true,
      "blockExternalImages": true,
      "fallbackToPlaceholder": true
    },
    "cssEnforcement": {
      "lockPrimaryColor": true,
      "lockFontFamily": true,
      "injectBrandWatermark": true
    },
    "buildChecks": {
      "lintBrandColors": true,
      "lintImageSources": true,
      "lintLogoPresence": true
    }
  }
}
