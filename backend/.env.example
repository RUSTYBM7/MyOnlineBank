# OrbitPay Backend Environment Variables

NODE_ENV=production
PORT=3001

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# JWT Authentication
JWT_SECRET=orbitpay-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://orbitpay.com

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@orbitpay.com

# SMS / 2FA (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI Assistant (Optional)
OPENAI_API_KEY=
