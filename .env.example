# OrbitPay Environment Variables

# Frontend (Vite)
VITE_API_URL=https://api.orbitpay.com
VITE_APP_NAME=OrbitPay
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://myonlinebank.vercel.app

# Google Analytics & Ads
VITE_GA_ID=G-MOBILE_APP_CONFIG
VITE_GOOGLE_ADS_ID=AW-MOBILE_APP_CONFIG
VITE_GTM_ID=GTM-MOBILE_APP_CONFIG

# Backend
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL="file:./prod.db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=https://orbitpay.com,https://www.orbitpay.com

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Email (for production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@orbitpay.com
SMTP_PASS=your-smtp-password

# SMS (for MFA)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# AI Assistant (Optional)
OPENAI_API_KEY=your-openai-api-key
