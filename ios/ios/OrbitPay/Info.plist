<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Identity -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>OrbitPay</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Interface -->
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>

	<!-- Appearance -->
	<key>UIUserInterfaceStyle</key>
	<string>Automatic</string>

	<!-- Privacy Descriptions (required for App Store) -->
	<key>NSCameraUsageDescription</key>
	<string>OrbitPay needs camera access to take selfies for KYC identity verification.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>OrbitPay needs photo library access to upload identity documents for KYC verification.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>OrbitPay saves transaction receipts and screenshots to your photo library.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>OrbitPay uses Face ID to securely authenticate you without entering your password.</string>
	<key>NSContactsUsageDescription</key>
	<string>OrbitPay accesses contacts to make it easy to send money to people you know.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>OrbitPay may use the microphone for voice-assisted support features.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>OrbitPay uses your location to detect nearby ATMs and flag suspicious transactions.</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>OrbitPay uses tracking to provide personalized financial insights and improve app experience.</string>

	<!-- Push Notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>

	<!-- Deep Linking -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>orbitpay</string>
			</array>
		</dict>
	</array>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>orbitpay</string>
	</array>

	<!-- App Transport Security -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!-- Entitlements Reference -->
	<key>CODE_SIGN_ENTITLEMENTS</key>
	<string>OrbitPay/OrbitPay.entitlements</string>
</dict>
</plist>
