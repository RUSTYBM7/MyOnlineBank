{
  "name": "OrbitPayApp",
  "version": "1.0.0",
  "private": true,
  "description": "OrbitPay Credit Union Mobile Banking Application",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "ios:device": "react-native run-ios --device",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "build:ios": "react-native bundle --entry-file index.js --platform ios --dev false --bundle-output ios/main.jsbundle --assets-dest ios/assets",
    "build:ipa": "cd ios && fastlane build_ipa",
    "build:ipa:release": "cd ios && fastlane release",
    "clean": "npx react-native clean",
    "pods": "cd ios && pod install"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/stack": "^6.3.29",
    "@reduxjs/toolkit": "^2.3.0",
    "react": "18.3.1",
    "react-native": "0.75.5",
    "react-native-biometrics": "^3.0.1",
    "react-native-camera": "^4.2.1",
    "react-native-document-picker": "^9.3.1",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "^2.19.0",
    "react-native-keychain": "^8.2.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-permissions": "^4.1.5",
    "react-native-push-notification": "^8.1.1",
    "react-native-reanimated": "^3.15.0",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-screens": "^3.34.0",
    "react-native-svg": "^15.6.0",
    "react-native-vector-icons": "^10.2.0",
    "react-redux": "^9.1.2",
    "@notifee/react-native": "^9.1.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-image-picker": "^7.1.2",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-blur": "^4.4.1",
    "react-native-modal": "^13.0.1",
    "react-native-masked-text": "^1.13.0",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-toast-message": "^2.2.1",
    "react-native-config": "^1.5.3",
    "axios": "^1.7.7",
    "date-fns": "^4.1.0",
    "zustand": "^5.0.1",
    "@tanstack/react-query": "^5.59.15",
    "immer": "^10.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@babel/runtime": "^7.25.6",
    "@react-native/babel-preset": "^0.75.5",
    "@react-native/eslint-config": "^0.75.5",
    "@react-native/metro-config": "^0.75.5",
    "@react-native/typescript-config": "^0.75.5",
    "@types/react": "^18.3.10",
    "@types/react-native": "^0.73.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"]
  }
}
